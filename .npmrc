# ==============================================================================
# pnpm Security and Resolution Safeguards (pnpm v10 and below compatibility)
# ==============================================================================

# Force a single shared lockfile at the workspace root to ensure uniform dependency auditing
shared-workspace-lockfile=true

# Enforce strict peer dependency validation to prevent incompatible or vulnerable dependency resolutions
strict-peer-dependencies=true

# Disable dependency hoisting to prevent "phantom dependencies" (accessing undeclared sub-dependencies)
hoist=false
public-hoist-pattern[]=*

# Require pnpm to verify package integrity and ensure the lockfile is up to date during CI
frozen-lockfile=true
